# -----------------------------------------------------------------------------
# 1. Terraform Cloud (REQUIRED)
# -----------------------------------------------------------------------------
tfc_organization = "your-org-name"
tfc_workspace    = "openclaw-native"

# -----------------------------------------------------------------------------
# 2. AWS Region (optional)
# -----------------------------------------------------------------------------
aws_region = "us-east-1"

# -----------------------------------------------------------------------------
# 3. OpenRouter API Key (REQUIRED) - Get free key at https://openrouter.ai/keys
# -----------------------------------------------------------------------------
openrouter_api_key = "sk-or-v1-..."

# -----------------------------------------------------------------------------
# 4. Security (RESTRICT THESE!)
# -----------------------------------------------------------------------------
ssh_allowed_cidrs = ["0.0.0.0/0"]
allowed_cidrs     = ["0.0.0.0/0"]

# -----------------------------------------------------------------------------
# 5. Optional Overrides
# -----------------------------------------------------------------------------
# instance_type = "t3.small"
# default_model = "openrouter/auto"